;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Stress Librarian"
config/tags=PackedStringArray("ap")
run/main_scene="uid://dy53kd20h4anj"
config/features=PackedStringArray("4.5", "C#", "Forward Plus")
run/max_fps=100
config/icon="res://icon.svg"

[autoload]

GameManager="*res://Scripts/Global/GameManager.cs"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=false
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="Stress Librarian"

